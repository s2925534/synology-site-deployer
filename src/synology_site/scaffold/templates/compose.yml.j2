services:
  {{ slug }}:
    build:
      context: ./app
    container_name: {{ slug }}
    restart: {{ restart_policy }}
    ports:
      - "{{ port }}:{{ internal_port }}"
{% if db_enabled %}
    env_file:
      - ./app/.env
{% endif %}
{% if db_enabled or redis_enabled %}
    depends_on:
{% if db_enabled %}
      {{ db_container }}:
        condition: service_healthy
{% endif %}
{% if redis_enabled %}
      {{ redis_container }}:
        condition: service_healthy
{% endif %}
    networks:
      - {{ db_network }}
{% endif %}
{% if db_enabled %}

  {{ db_container }}:
    image: {{ db_image }}
    container_name: {{ db_container }}
    restart: {{ restart_policy }}
    environment:
      MARIADB_ROOT_PASSWORD: {{ db_root_password }}
      MARIADB_DATABASE: {{ db_name }}
      MARIADB_USER: {{ db_user }}
      MARIADB_PASSWORD: {{ db_password }}
{% if db_publish_port and db_host_port %}
    ports:
      - "{{ db_host_port }}:3306"
{% endif %}
    volumes:
      - {{ db_volume }}:/var/lib/mysql
    networks:
      - {{ db_network }}
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% if redis_enabled %}

  {{ redis_container }}:
    image: redis:7-alpine
    container_name: {{ redis_container }}
    restart: {{ restart_policy }}
    volumes:
      - {{ redis_volume }}:/data
    networks:
      - {{ db_network }}
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% if queue_enabled %}

  {{ slug }}-queue:
    build:
      context: ./app
    container_name: {{ slug }}-queue
    restart: {{ restart_policy }}
    command: ["php", "artisan", "queue:work", "--sleep=3", "--tries=3", "--max-time=3600"]
    depends_on:
      {{ redis_container }}:
        condition: service_healthy
{% if db_enabled %}
      {{ db_container }}:
        condition: service_healthy
{% endif %}
    networks:
      - {{ db_network }}
{% endif %}
{% if db_enabled or redis_enabled %}

volumes:
{% if db_enabled %}
  {{ db_volume }}:
{% endif %}
{% if redis_enabled %}
  {{ redis_volume }}:
{% endif %}

networks:
  {{ db_network }}:
{% endif %}
