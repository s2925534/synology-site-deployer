FROM composer:2 AS build
WORKDIR /app
RUN composer create-project --prefer-dist --no-interaction laravel/laravel:^11.0 .
COPY .env .env
COPY routes-extra.php /tmp/routes-extra.php
RUN cat /tmp/routes-extra.php >> routes/web.php
RUN php artisan key:generate --force

FROM php:8.3-cli
COPY --from=mlocati/docker-php-extension-installer:latest /usr/bin/install-php-extensions /usr/local/bin/
RUN install-php-extensions pdo_mysql pdo_sqlite mbstring
WORKDIR /app
COPY --from=build /app /app
EXPOSE 8000
CMD ["php", "artisan", "serve", "--host=0.0.0.0", "--port=8000"]
