services:
  {{ slug }}:
    build:
      context: ./app
      target: php-fpm
    container_name: {{ slug }}
    restart: {{ restart_policy }}
{% if db_enabled %}
    env_file:
      - ./app/.env
{% endif %}
{% if db_mode == "container" or redis_enabled %}
    depends_on:
{% if db_mode == "container" %}
      {{ db_container }}:
        condition: service_healthy
{% endif %}
{% if redis_enabled %}
      {{ redis_container }}:
        condition: service_healthy
{% endif %}
{% endif %}
{% if needs_private_network or needs_shared_network %}
    networks:
{% if needs_private_network %}
      - {{ db_network }}
{% endif %}
{% if needs_shared_network %}
      - {{ shared_db_network }}
{% endif %}
      - default
{% endif %}

  {{ slug }}-web:
    build:
      context: ./app
      target: nginx
    container_name: {{ slug }}-web
    restart: {{ restart_policy }}
    ports:
      - "{{ port }}:80"
    depends_on:
      - {{ slug }}
{% if needs_private_network or needs_shared_network %}
    networks:
      - default
{% endif %}
{% if db_mode == "container" %}

  {{ db_container }}:
    image: {{ db_image }}
    container_name: {{ db_container }}
    restart: {{ restart_policy }}
    environment:
      MARIADB_ROOT_PASSWORD: {{ db_root_password }}
      MARIADB_DATABASE: {{ db_name }}
      MARIADB_USER: {{ db_user }}
      MARIADB_PASSWORD: {{ db_password }}
{% if db_publish_port and db_host_port %}
    ports:
      - "{{ db_host_port }}:3306"
{% endif %}
    volumes:
      - {{ db_volume }}:/var/lib/mysql
    networks:
      - {{ db_network }}
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% if redis_enabled %}

  {{ redis_container }}:
    image: redis:7-alpine
    container_name: {{ redis_container }}
    restart: {{ restart_policy }}
    volumes:
      - {{ redis_volume }}:/data
    networks:
      - {{ db_network }}
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% if queue_enabled %}

  {{ slug }}-queue:
    build:
      context: ./app
      target: php-fpm
    container_name: {{ slug }}-queue
    restart: {{ restart_policy }}
    command: ["php", "artisan", "queue:work", "--sleep=3", "--tries=3", "--max-time=3600"]
    depends_on:
      {{ redis_container }}:
        condition: service_healthy
{% if db_mode == "container" %}
      {{ db_container }}:
        condition: service_healthy
{% endif %}
    networks:
      - {{ db_network }}
{% if needs_shared_network %}
      - {{ shared_db_network }}
{% endif %}
      - default
{% endif %}
{% if scheduler_enabled %}

  {{ slug }}-scheduler:
    build:
      context: ./app
      target: php-fpm
    container_name: {{ slug }}-scheduler
    restart: {{ restart_policy }}
    command: ["sh", "-c", "while true; do php artisan schedule:run --verbose --no-interaction; sleep 60; done"]
{% if db_mode == "container" or redis_enabled %}
    depends_on:
{% if db_mode == "container" %}
      {{ db_container }}:
        condition: service_healthy
{% endif %}
{% if redis_enabled %}
      {{ redis_container }}:
        condition: service_healthy
{% endif %}
{% endif %}
{% if needs_private_network or needs_shared_network %}
    networks:
{% if needs_private_network %}
      - {{ db_network }}
{% endif %}
{% if needs_shared_network %}
      - {{ shared_db_network }}
{% endif %}
      - default
{% endif %}
{% endif %}
{% if needs_private_network %}

volumes:
{% if db_mode == "container" %}
  {{ db_volume }}:
{% endif %}
{% if redis_enabled %}
  {{ redis_volume }}:
{% endif %}
{% endif %}
{% if needs_private_network or needs_shared_network %}

networks:
{% if needs_private_network %}
  {{ db_network }}:
{% endif %}
{% if needs_shared_network %}
  {{ shared_db_network }}:
    external: true
{% endif %}
  default:
{% endif %}
