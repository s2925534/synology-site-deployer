APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://{{ domain }}

LOG_CHANNEL=stack
LOG_LEVEL=error

{% if db_enabled %}
DB_CONNECTION=mysql
DB_HOST={{ db_container }}
DB_PORT=3306
DB_DATABASE={{ db_name }}
DB_USERNAME={{ db_user }}
DB_PASSWORD={{ db_password }}
{% else %}
DB_CONNECTION=sqlite
{% endif %}

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
