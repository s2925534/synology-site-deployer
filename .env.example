# Synology SSH
NAS_HOST=192.168.1.100
NAS_PORT=22
NAS_USER=your_synology_username
NAS_DOCKER_ROOT=/volume1/docker

# Authentication
# Prefer SSH key if available.
NAS_SSH_KEY_PATH=
NAS_SSH_PASSWORD=

# Local NAS network
# This is the IP or hostname that Cloudflare Tunnel and local checks should use to reach the NAS.
LOCAL_BASE_URL_HOST=192.168.1.100
DEFAULT_START_PORT=5050
DEFAULT_END_PORT=5999

# Default site domain
# When a domain argument passed to `create`/`deploy` has no dot in it (e.g. "app"),
# it is expanded to "<name>.DEFAULT_SITE_DOMAIN" (e.g. "app.example.com"). Domains
# that already contain a dot are left untouched. Leave empty to disable.
DEFAULT_SITE_DOMAIN=example.com

# Defaults
DEFAULT_FRAMEWORK=flask
DEFAULT_CONTAINER_RESTART_POLICY=unless-stopped

# Cloudflare optional
# If these are missing, the tool must skip automatic Cloudflare setup
# and print manual instructions instead.
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_ZONE_DOMAIN=example.com
CF_TUNNEL_ID=
CF_TUNNEL_NAME=my-nas-tunnel

# Database
# none      = no database
# container = create MariaDB container inside the generated Docker Compose project
# external  = future support only, do not prioritize in version 1
DB_MODE=none
DB_TYPE=mariadb
DB_IMAGE=mariadb:11
DB_PASSWORD_LENGTH=32

# MariaDB container options
DB_PUBLISH_PORT=false
DB_HOST_PORT=

# Safety
ALLOW_OVERWRITE=false
DRY_RUN=false
